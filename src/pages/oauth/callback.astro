---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
---

<PageLayout title="Authenticating..." description="Bluesky (AT Protocol) OAuth callback handler">
  <Container>
    <div class="flex flex-col items-center justify-center py-20 gap-3">
      <div class="w-5 h-5 rounded-full border-2 border-black/20 dark:border-white/20 border-t-black/60 dark:border-t-white/60 animate-spin"></div>
      <p class="text-sm opacity-60">Completing sign-in, please wait…</p>
    </div>
  </Container>
</PageLayout>

<script>
  // Bluesky (AT Protocol) only — Mastodon has its own callback page at
  // /oauth/mastodon-callback, so there's no need to sniff which flow this is.
  import { BrowserOAuthClient, LoginContinuedInParentWindowError } from "@atproto/oauth-client-browser";

  (async () => {
    const isLoopback = location.hostname === "localhost" || location.hostname === "127.0.0.1";
    const clientId = isLoopback
      ? `http://localhost?redirect_uri=${encodeURIComponent(`http://127.0.0.1:${location.port}/oauth/callback`)}&scope=${encodeURIComponent("atproto transition:generic")}`
      : `${location.origin}/client-metadata.json`;

    try {
      const client = await BrowserOAuthClient.load({ clientId, handleResolver: "https://bsky.social" });
      // Reads the callback params from the URL, exchanges the code, and — when this
      // page was opened as a popup by signInPopup() — notifies the opener over a
      // BroadcastChannel and closes this window itself, throwing
      // LoginContinuedInParentWindowError by design once that's done.
      await client.init();
      if (window.opener) {
        window.opener.postMessage({ type: "fedi-bsky-auth" }, location.origin);
        window.close();
        return;
      }

      // Reached only for a same-tab redirect (no popup involved): go back to the article.
      location.href = localStorage.getItem("fedi-oauth-return-to") ?? "/";
    } catch (e) {
      if (e instanceof LoginContinuedInParentWindowError) return; // window is already closed
      console.error("Bluesky sign-in failed:", e);
      if (window.opener) window.close();
      else location.href = localStorage.getItem("fedi-oauth-return-to") ?? "/";
    }
  })();
</script>

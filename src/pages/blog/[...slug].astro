---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";
import ProgressBar from "@components/ProgressBar.astro";
import FediverseComments from "@components/FediverseComments.astro";

export async function getStaticPaths() {
    // drafts stay reachable by URL in dev, but are never built for production
    const posts = (await getCollection("blog"))
        .filter((post) => import.meta.env.DEV || !post.data.draft)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: post,
    }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();
---

<PageLayout title={post.data.title} description={post.data.description} image={`/og/${post.slug}.png`}>
    <Container>
        <ProgressBar />
        <div class="">
            <BackToPrev href="/blog"> Back to blog </BackToPrev>
        </div>
        <div class="space-y-3 my-10">
            <div class="flex items-center gap-3 mono-label">
                <span>
                    <FormattedDate date={post.data.date} />
                </span>
                <span class="text-[var(--border-strong)]">·</span>
                <span>
                    {readingTime(post.body)}
                </span>
            </div>
            <h1
                class="font-display text-3xl font-medium tracking-tight leading-tight text-[var(--text-primary)] pb-4 border-b-2 border-[var(--rule-strong)]"
            >
                {post.data.title}
            </h1>
        </div>
        <article class="post-article">
            <Content />
        </article>
        <FediverseComments
            blueskyPostUri={post.data.blueskyPostUri}
            mastodonPostUrl={post.data.mastodonPostUrl}
        />
    </Container>
</PageLayout>

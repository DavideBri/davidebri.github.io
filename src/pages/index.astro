---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";

const allBlog = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const blog = allBlog.slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const allProjects = (await getCollection("projects"))
    .filter((project) => !project.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const projects = allProjects.slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
    <Container>
        <div class="space-y-20">
            <!-- Hero Section -->
            <section class="pt-1">
                <div class="flex items-center gap-6 mb-8">
                    <img
                        src="https://avatars.githubusercontent.com/u/70480082?v=4"
                        alt="Davide's profile picture"
                        class="w-24 h-24 rounded-[2px] object-cover border-[3px] border-[var(--accent)] shadow-[0_0_0_3px_var(--accent-subtle)]"
                    />
                    <div>
                        <h1 class="font-display text-3xl font-medium tracking-tight text-[var(--text-primary)] mb-2">
                            Davide Brienza<span class="text-[var(--accent)]">.</span>
                        </h1>
                        <p class="mono-label mono-label-accent">
                            @DavideBri
                        </p>
                    </div>
                </div>

                <div class="max-w-2xl">
                    <p class="text-md leading-7 text-[var(--text-primary)] mb-8 max-w-2xl">
                        Backend developer from Pisa who gets <span class="marker">obsessively curious</span> about things. <br>
                        Currently deep in the decentralized networks rabbit hole.<br>
                        When I'm not coding, I'm either spiking volleyballs,
                        fixing/building random stuff, or gesturing dramatically while talking.
                    </p>
                <div class="dc-callout dc-callout-neutral">
                    <p class="text-sm text-[var(--text-muted)]">
                        Fun fact: my YouTube history is 40% tech talks, 30% DIY tutorials, 30% volleyball clips
                    </p>
                </div>
                </div>
            </section>

            <!-- Latest Posts -->
            <section>
                <div class="flex items-end justify-between mb-4">
                    <h2 class="mono-label text-[12px]">
                        Latest posts
                    </h2>
                    <a href="/blog" class="standalone-link text-sm">
                        See all posts →
                    </a>
                </div>

                <div class="border-b border-[var(--border)]">
                    {blog.map((post, i) => (
                        <ArrowCard entry={post} index={allBlog.length - i} />
                    ))}
                </div>
            </section>

            <!-- Recent Projects -->
            <section>
                <div class="flex items-end justify-between mb-4">
                    <h2 class="mono-label text-[12px]">
                        Recent projects
                    </h2>
                    <a href="/projects" class="standalone-link text-sm">
                        See all projects →
                    </a>
                </div>

                <div class="border-b border-[var(--border)]">
                    {projects.map((project, i) => (
                        <ArrowCard entry={project} index={allProjects.length - i} />
                    ))}
                </div>
            </section>

            <!-- Connect Section -->
            <section>
                <h2 class="mono-label text-[12px] mb-6">
                    Let's connect
                </h2>

                <div class="space-y-6">
                    <div class="max-w-2xl">
                        <p class="text-[var(--text-primary)] leading-relaxed mb-4">
                            Interested in Web3? <br>
                            Looking for speakers for your next conference? <br>
                            Want to master the art of gesturing like a true Italian? <br>
                        </p>
                        <p class="text-[var(--text-secondary)]">
                            Feel free to reach out—whether it's just to chat, collaborate, or share ideas!
                        </p>
                    </div>

                    <div class="flex flex-wrap items-center gap-4 text-sm">
                        {SOCIALS.map((social, index) => (
                            <span class="flex items-center gap-2">
                                <Link
                                    href={social.HREF}
                                    external
                                    aria-label={`${SITE.NAME} on ${social.NAME}`}
                                >
                                    {social.NAME}
                                </Link>
                                {index < SOCIALS.length - 1 && (
                                    <span class="text-[var(--border-strong)]">/</span>
                                )}
                            </span>
                        ))}
                        <span class="flex items-center gap-2">
                            <span class="text-[var(--border-strong)]">/</span>
                            <Link
                                href={`mailto:${SITE.EMAIL}`}
                                aria-label={`Email ${SITE.NAME}`}
                            >
                                {SITE.EMAIL}
                            </Link>
                        </span>
                    </div>
                </div>
            </section>

            <!-- Footer Spacer -->
            <div class="h-16"></div>
        </div>
    </Container>
</PageLayout>

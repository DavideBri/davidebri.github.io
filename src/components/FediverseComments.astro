---
type Props = {
  blueskyPostUri?: string;
  mastodonPostUrl?: string;
};

const { blueskyPostUri, mastodonPostUrl } = Astro.props;
if (!blueskyPostUri && !mastodonPostUrl) return;

const hasBluesky = !!blueskyPostUri;
const hasMastodon = !!mastodonPostUrl;
---

<section
  id="fediverse-comments"
  class="mt-16 pt-8 border-t border-[var(--border)]"
  data-bsky-uri={blueskyPostUri}
  data-mastodon-url={mastodonPostUrl}
  aria-label="Comments"
>
  <div class="flex items-baseline justify-between mb-6 gap-3 flex-wrap">
    <h2 class="text-lg font-semibold text-black dark:text-white">Comments</h2>

    <!-- Unified action row: one like, one reply count, agnostic of network -->
    <div class="flex items-center gap-2">
      <button
        id="like-btn"
        title="Like this post"
        class="flex items-center gap-1.5 px-3 py-1.5 rounded-[2px] border text-sm transition-colors duration-300 ease-in-out border-[var(--border)] hover:bg-[var(--surface-subtle)] hover:border-[var(--border-accent)] disabled:cursor-not-allowed"
      >
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-4 fill-none stroke-current stroke-2">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <span id="like-count" class="tabular-nums">—</span>
      </button>
      <div class="flex items-center gap-1.5 px-3 py-1.5 text-sm opacity-50" title="Replies">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-4 fill-none stroke-current stroke-2">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        <span id="reply-count" class="tabular-nums">—</span>
      </div>
    </div>
  </div>

  <!-- Composer: always writable. Auth is requested only on send. -->
  <div id="fedi-composer" class="mb-8">

    <!-- Signed-in header (hidden until authenticated) -->
    <div id="fedi-user-bar" class="hidden items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <img id="fedi-user-avatar" src="" alt="" class="w-6 h-6 rounded-full border border-black/10 dark:border-white/10" />
        <span class="text-sm font-medium text-black dark:text-white">@<span id="fedi-user-handle"></span></span>
        <span id="fedi-platform-badge" class="text-xs opacity-50"></span>
      </div>
      <button id="btn-logout" class="text-xs opacity-50 hover:opacity-100 transition-opacity duration-200">
        Sign out
      </button>
    </div>

    <!-- Single seamless field: textarea + actions share one border -->
    <div class="rounded-lg border border-[var(--border)] focus-within:border-[var(--border-focus)] transition-colors duration-200 px-3 pt-3 pb-2">
      <textarea
        id="fedi-comment-input"
        rows="3"
        placeholder="Add to the discussion…"
        class="w-full text-sm bg-transparent resize-none focus:outline-none placeholder:opacity-40"
      ></textarea>
      <div class="flex items-center justify-between mt-1">
        <span id="fedi-char-count" class="text-xs opacity-40"></span>
        <button
          id="btn-submit-comment"
          class="px-3 py-1 rounded-[2px] text-sm text-black dark:text-white transition-colors duration-200 hover:bg-[var(--surface-subtle)] disabled:opacity-40 disabled:cursor-not-allowed"
        >
          Post reply
        </button>
      </div>
    </div>
    <p id="fedi-submit-status" class="hidden mt-2 text-xs opacity-60"></p>

    <!-- Protocol chooser: appears when an action needs auth -->
    <div id="fedi-chooser" class="hidden mt-4">
      <p id="fedi-chooser-prompt" class="text-sm opacity-60 mb-3">Choose how to sign in</p>
      <div class="flex flex-wrap gap-2">
        {hasBluesky && (
          <button
            data-proto="atproto"
            class="fedi-proto-btn flex items-center gap-2 px-3 py-2 rounded-[2px] border text-sm text-left transition-colors duration-300 ease-in-out border-[var(--border)] hover:bg-[var(--surface-subtle)] hover:border-[var(--border-accent)]"
          >
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 360 320" fill="currentColor">
              <path d="M180 142c-16.3-31.7-60.7-90.8-102-120C38.5-5.9 36.3-4 23.4 0 13.5 3.1 0 21.4 0 30.5c0 9 14.3 57.3 19.5 70 10.5 26.8 31.2 43.6 52 49.3 37.4 10.4 79.1 2.9 79.1 2.9s-12.4 1.7-24.2 6.6c-11.4 4.7-48.1 26.3-57.7 100.6C66.1 302 81.5 320 98.5 320c15.4 0 47.8-22.8 63.5-50 8.2-14.2 18-28.6 18-28.6s9.8 14.4 18 28.6c15.7 27.2 48 50 63.5 50 17 0 32.4-18 29.8-60.1-9.6-74.3-46.3-95.9-57.7-100.6-11.8-4.9-24.2-6.6-24.2-6.6s41.7 7.5 79.1-2.9c20.8-5.7 41.5-22.5 52-49.3 5.2-12.7 19.5-61 19.5-70 0-9.1-13.5-27.4-23.4-30.5C304.3-4 302.1-5.9 262 22c-41.3 29.2-85.7 88.3-102 120z"/>
            </svg>
            <span class="flex flex-col leading-tight">
              <span class="font-medium text-black dark:text-white">AT Protocol</span>
              <span class="text-xs opacity-50">Bluesky</span>
            </span>
          </button>
        )}
        {hasMastodon && (
          <button
            data-proto="activitypub"
            class="fedi-proto-btn flex items-center gap-2 px-3 py-2 rounded-[2px] border text-sm text-left transition-colors duration-300 ease-in-out border-[var(--border)] hover:bg-[var(--surface-subtle)] hover:border-[var(--border-accent)]"
          >
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.012-3.13C6.487 4.199 7.408 3.8 8.567 3.8c1.339 0 2.354.514 3.028 1.542l.653 1.092.654-1.092c.673-1.028 1.688-1.542 3.027-1.542 1.159 0 2.08.399 2.734 1.172.675.78 1.012 1.82 1.012 3.13z"/>
            </svg>
            <span class="flex flex-col leading-tight">
              <span class="font-medium text-black dark:text-white">ActivityPub</span>
              <span class="text-xs opacity-50">Mastodon</span>
            </span>
          </button>
        )}
      </div>

      {hasBluesky && (
        <div id="bsky-login-form" class="hidden mt-3">
          <label class="text-xs opacity-50">Your Bluesky handle</label>
          <div class="flex gap-2 mt-1">
            <input
              id="bsky-handle-input"
              type="text"
              placeholder="alice.bsky.social"
              class="flex-1 text-sm rounded-[2px] border border-[var(--border)] bg-transparent px-2 py-1.5 focus:outline-none focus:border-black/40 dark:focus:border-white/40 transition-colors"
            />
            <button
              id="btn-bsky-signin"
              class="px-3 py-1.5 rounded-[2px] border text-sm transition-colors duration-300 ease-in-out border-[var(--border)] hover:bg-[var(--surface-subtle)] hover:border-[var(--border-accent)] whitespace-nowrap"
            >
              Continue →
            </button>
          </div>
          <p id="bsky-login-error" class="hidden mt-1.5 text-xs text-red-500 dark:text-red-400"></p>
        </div>
      )}

      {hasMastodon && (
        <div id="masto-login-form" class="hidden mt-3">
          <label class="text-xs opacity-50">Your Mastodon instance</label>
          <div class="flex gap-2 mt-1">
            <input
              id="masto-instance-input"
              type="text"
              placeholder="mastodon.social"
              class="flex-1 text-sm rounded-[2px] border border-[var(--border)] bg-transparent px-2 py-1.5 focus:outline-none focus:border-black/40 dark:focus:border-white/40 transition-colors"
            />
            <button
              id="btn-masto-signin"
              class="px-3 py-1.5 rounded-[2px] border text-sm transition-colors duration-300 ease-in-out border-[var(--border)] hover:bg-[var(--surface-subtle)] hover:border-[var(--border-accent)] whitespace-nowrap"
            >
              Continue →
            </button>
          </div>
          <p id="masto-login-error" class="hidden mt-1.5 text-xs text-red-500 dark:text-red-400"></p>
        </div>
      )}
    </div>
  </div>

  <!-- Unified comment stream (both networks merged chronologically) -->
  <div id="fedi-stream">
    <div id="fedi-loading" class="space-y-4">
      {[0,1].map(() => (
        <div class="flex gap-3 py-3">
          <div class="w-8 h-8 rounded-full animate-pulse bg-black/5 dark:bg-white/5 flex-shrink-0"></div>
          <div class="flex-1 space-y-2">
            <div class="h-3 w-32 animate-pulse bg-black/5 dark:bg-white/5 rounded"></div>
            <div class="h-3 w-full animate-pulse bg-black/5 dark:bg-white/5 rounded"></div>
            <div class="h-3 w-4/5 animate-pulse bg-black/5 dark:bg-white/5 rounded"></div>
          </div>
        </div>
      ))}
    </div>

    <div id="fedi-comments" class="hidden divide-y divide-black/10 dark:divide-white/10"></div>
    <div id="fedi-empty" class="hidden text-sm opacity-60 py-4">No replies yet. Be the first!</div>
    <div id="fedi-error" class="hidden text-sm opacity-60 py-4">Could not load comments.</div>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mt-6">
      {hasBluesky && (
        <a
          href={blueskyPostUri}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm opacity-50 hover:opacity-100 transition-opacity duration-200"
        >
          <svg aria-hidden="true" width="13" height="13" viewBox="0 0 360 320" fill="currentColor">
            <path d="M180 142c-16.3-31.7-60.7-90.8-102-120C38.5-5.9 36.3-4 23.4 0 13.5 3.1 0 21.4 0 30.5c0 9 14.3 57.3 19.5 70 10.5 26.8 31.2 43.6 52 49.3 37.4 10.4 79.1 2.9 79.1 2.9s-12.4 1.7-24.2 6.6c-11.4 4.7-48.1 26.3-57.7 100.6C66.1 302 81.5 320 98.5 320c15.4 0 47.8-22.8 63.5-50 8.2-14.2 18-28.6 18-28.6s9.8 14.4 18 28.6c15.7 27.2 48 50 63.5 50 17 0 32.4-18 29.8-60.1-9.6-74.3-46.3-95.9-57.7-100.6-11.8-4.9-24.2-6.6-24.2-6.6s41.7 7.5 79.1-2.9c20.8-5.7 41.5-22.5 52-49.3 5.2-12.7 19.5-61 19.5-70 0-9.1-13.5-27.4-23.4-30.5C304.3-4 302.1-5.9 262 22c-41.3 29.2-85.7 88.3-102 120z"/>
          </svg>
          View on Bluesky
        </a>
      )}
      {hasMastodon && (
        <a
          href={mastodonPostUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm opacity-50 hover:opacity-100 transition-opacity duration-200"
        >
          <svg aria-hidden="true" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.012-3.13C6.487 4.199 7.408 3.8 8.567 3.8c1.339 0 2.354.514 3.028 1.542l.653 1.092.654-1.092c.673-1.028 1.688-1.542 3.027-1.542 1.159 0 2.08.399 2.734 1.172.675.78 1.012 1.82 1.012 3.13z"/>
          </svg>
          View on Mastodon
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .fedi-comment-content p { margin: 0; }
  .fedi-comment-content a { text-decoration: underline; text-underline-offset: 2px; }
  .fedi-avatar-fallback {
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 600; color: white;
  }
  #fedi-user-bar:not(.hidden) { display: flex; }
</style>

<script>
  import { BrowserOAuthClient } from "@atproto/oauth-client-browser";
  import type { OAuthSession } from "@atproto/oauth-client";

  // ── Root & data ─────────────────────────────────────────────────────────────
  const root = document.getElementById("fediverse-comments") as HTMLElement;
  const bskyRawUri = root.dataset.bskyUri ?? "";
  const mastoRawUrl = root.dataset.mastodonUrl ?? "";

  // Which protocols this post can talk to
  const availableProtos: ("atproto" | "activitypub")[] = [];
  if (bskyRawUri) availableProtos.push("atproto");
  if (mastoRawUrl) availableProtos.push("activitypub");

  // Module-level state
  let bskyAtUri = "";
  let bskyCid = "";
  let bskyClient: BrowserOAuthClient | null = null;
  let bskySession: OAuthSession | null = null;
  type MastoSession = { instance: string; access_token: string; acct: string; displayName: string; avatar: string };
  let mastoSession: MastoSession | null = null;

  let activePlatform: "bluesky" | "mastodon" | null = null;
  let pendingAction: "like" | "comment" | null = null;

  // ── Unified comment store ────────────────────────────────────────────────────
  type Comment = {
    platform: "bluesky" | "mastodon";
    name: string;
    handle: string;
    avatar: string;
    permalink: string;    // link to open this reply on its network ("#" if unknown)
    html: string;         // safe HTML for the body
    date: string;         // ISO
    likeCount: number;
  };
  const comments: Comment[] = [];
  let totalLikes = 0;
  let totalReplies = 0;
  let loadedCount = 0;
  let erroredCount = 0;

  const PLATFORM_ICON: Record<Comment["platform"], string> = {
    bluesky: `<svg aria-hidden="true" width="12" height="12" viewBox="0 0 360 320" fill="currentColor"><path d="M180 142c-16.3-31.7-60.7-90.8-102-120C38.5-5.9 36.3-4 23.4 0 13.5 3.1 0 21.4 0 30.5c0 9 14.3 57.3 19.5 70 10.5 26.8 31.2 43.6 52 49.3 37.4 10.4 79.1 2.9 79.1 2.9s-12.4 1.7-24.2 6.6c-11.4 4.7-48.1 26.3-57.7 100.6C66.1 302 81.5 320 98.5 320c15.4 0 47.8-22.8 63.5-50 8.2-14.2 18-28.6 18-28.6s9.8 14.4 18 28.6c15.7 27.2 48 50 63.5 50 17 0 32.4-18 29.8-60.1-9.6-74.3-46.3-95.9-57.7-100.6-11.8-4.9-24.2-6.6-24.2-6.6s41.7 7.5 79.1-2.9c20.8-5.7 41.5-22.5 52-49.3 5.2-12.7 19.5-61 19.5-70 0-9.1-13.5-27.4-23.4-30.5C304.3-4 302.1-5.9 262 22c-41.3 29.2-85.7 88.3-102 120z"/></svg>`,
    mastodon: `<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.012-3.13C6.487 4.199 7.408 3.8 8.567 3.8c1.339 0 2.354.514 3.028 1.542l.653 1.092.654-1.092c.673-1.028 1.688-1.542 3.027-1.542 1.159 0 2.08.399 2.734 1.172.675.78 1.012 1.82 1.012 3.13z"/></svg>`,
  };
  const PLATFORM_LABEL: Record<Comment["platform"], string> = { bluesky: "Bluesky", mastodon: "Mastodon" };

  // ── DOM helpers ─────────────────────────────────────────────────────────────
  function showEl(id: string) { document.getElementById(id)?.classList.remove("hidden"); }
  function hideEl(id: string) { document.getElementById(id)?.classList.add("hidden"); }

  function formatDate(iso: string): string {
    const d = new Date(iso);
    const diff = Date.now() - d.getTime();
    if (diff < 3_600_000) return `${Math.floor(diff / 60_000)}m ago`;
    if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)}h ago`;
    return d.toLocaleDateString(undefined, { month: "short", day: "numeric", year: "numeric" });
  }

  function avatarFallbackHtml(name: string): string {
    const colors = ["#6b7280","#8b5cf6","#ec4899","#06b6d4","#10b981","#f59e0b"];
    const idx = (name.charCodeAt(0) || 0) % colors.length;
    return `<div class="w-8 h-8 rounded-full flex-shrink-0 fedi-avatar-fallback border border-black/10 dark:border-white/10" style="background:${colors[idx]}">${(name[0]||"?").toUpperCase()}</div>`;
  }

  function makeAvatar(src: string, alt: string): string {
    if (!src) return avatarFallbackHtml(alt);
    // Escape " so the fallback markup can't break out of the onerror="" attribute.
    const fallback = avatarFallbackHtml(alt).replace(/"/g, "&quot;");
    return `<img src="${escapeHtml(src)}" alt="${escapeHtml(alt)}" loading="lazy" class="w-8 h-8 rounded-full flex-shrink-0 border border-black/10 dark:border-white/10" onerror="this.outerHTML='${fallback}';" />`;
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  // ── Stream rendering ─────────────────────────────────────────────────────────
  function renderComment(c: Comment): string {
    // Mastodon accounts often have no display name → name === handle. Show the
    // @handle only when it actually adds information.
    const showHandle = c.handle && c.handle !== c.name;
    const metaInner = `${PLATFORM_ICON[c.platform]}<span>${formatDate(c.date)}</span>`;
    const meta = c.permalink && c.permalink !== "#"
      ? `<a href="${escapeHtml(c.permalink)}" target="_blank" rel="noopener noreferrer" class="ml-auto inline-flex items-center gap-1 text-xs opacity-40 hover:opacity-100 transition-opacity" title="Open on ${PLATFORM_LABEL[c.platform]}">${metaInner}</a>`
      : `<span class="ml-auto inline-flex items-center gap-1 text-xs opacity-40" title="via ${PLATFORM_LABEL[c.platform]}">${metaInner}</span>`;
    return `<div class="flex gap-3 py-4">
      ${makeAvatar(c.avatar, c.name)}
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-baseline gap-x-1.5 mb-1">
          <span class="text-sm font-semibold text-black dark:text-white">${escapeHtml(c.name)}</span>
          ${showHandle ? `<span class="text-xs opacity-50">@${escapeHtml(c.handle)}</span>` : ""}
          ${meta}
        </div>
        <div class="text-sm leading-relaxed fedi-comment-content">${c.html}</div>
        ${c.likeCount > 0 ? `<div class="mt-1.5 text-xs opacity-50">♥ ${c.likeCount}</div>` : ""}
      </div>
    </div>`;
  }

  function renderStream() {
    const el = document.getElementById("fedi-comments");
    if (!el) return;
    // oldest → newest, reads as a conversation
    const sorted = [...comments].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
    if (sorted.length > 0) {
      el.innerHTML = sorted.map(renderComment).join("");
      showEl("fedi-comments");
      hideEl("fedi-empty");
    } else {
      hideEl("fedi-comments");
      // only claim "no replies" once everything that could load has loaded
      if (loadedCount + erroredCount >= availableProtos.length && erroredCount < availableProtos.length) {
        showEl("fedi-empty");
      }
    }
  }

  function updateTotals() {
    const likeEl = document.getElementById("like-count");
    const replyEl = document.getElementById("reply-count");
    if (likeEl) likeEl.textContent = String(totalLikes);
    if (replyEl) replyEl.textContent = String(totalReplies);
  }

  let loadFinished = false;
  function finishLoad() {
    if (loadFinished) return;
    loadFinished = true;
    hideEl("fedi-loading");
    if (erroredCount >= availableProtos.length && comments.length === 0) showEl("fedi-error");
    renderStream();
    updateTotals();
  }

  // ── Bluesky data fetch ───────────────────────────────────────────────────────
  async function loadBluesky(rawUri: string) {
    bskyAtUri = rawUri.startsWith("https://bsky.app/profile/")
      ? (() => { const p = rawUri.replace("https://bsky.app/profile/","").split("/post/"); return `at://${p[0]}/app.bsky.feed.post/${p[1]}`; })()
      : rawUri;

    const res = await fetch(`https://public.api.bsky.app/xrpc/app.bsky.feed.getPostThread?uri=${encodeURIComponent(bskyAtUri)}&depth=10`);
    if (!res.ok) throw new Error(`Bluesky ${res.status}`);
    const data = await res.json();

    const thread = data.thread;
    bskyCid = thread?.post?.cid ?? "";
    const likeCount: number = thread?.post?.likeCount ?? 0;
    const replies: any[] = (thread?.replies ?? []).filter((r: any) => r.$type === "app.bsky.feed.defs#threadViewPost");

    totalLikes += likeCount;
    totalReplies += replies.length;

    if (localStorage.getItem(`fedi-liked-bsky-${bskyAtUri}`)) markLikedBtn();

    for (const r of replies) {
      const p = r.post, a = p.author;
      const rkey = String(p.uri ?? "").split("/").pop();
      comments.push({
        platform: "bluesky",
        name: a.displayName || a.handle,
        handle: a.handle,
        avatar: a.avatar ?? "",
        permalink: rkey ? `https://bsky.app/profile/${a.handle}/post/${rkey}` : "#",
        html: `<p>${escapeHtml(p.record?.text ?? "")}</p>`,
        date: p.indexedAt,
        likeCount: p.likeCount ?? 0,
      });
    }
  }

  // ── Mastodon data fetch ──────────────────────────────────────────────────────
  async function loadMastodon(statusUrl: string) {
    const { hostname: instance, pathname } = new URL(statusUrl);
    const statusId = pathname.split("/").pop()!;

    const base = `https://${instance}/api/v1/statuses/${statusId}`;
    const [sRes, cRes] = await Promise.all([fetch(base), fetch(`${base}/context`)]);
    if (!sRes.ok) throw new Error(`Mastodon ${sRes.status}`);
    const status = await sRes.json();
    const context = await cRes.json();

    const likeCount: number = status.favourites_count ?? 0;
    const replies: any[] = (context.descendants ?? []).filter((s: any) => s.in_reply_to_id === statusId);

    totalLikes += likeCount;
    totalReplies += replies.length;

    if (localStorage.getItem(`fedi-liked-masto-${statusId}`)) markLikedBtn();

    for (const r of replies) {
      const acc = r.account;
      comments.push({
        platform: "mastodon",
        name: acc.display_name || acc.acct,
        handle: acc.acct,
        avatar: acc.avatar ?? "",
        permalink: r.url ?? r.uri ?? "#",
        html: r.content ?? "",
        date: r.created_at,
        likeCount: r.favourites_count ?? 0,
      });
    }
  }

  // ── Liked state ──────────────────────────────────────────────────────────────
  function markLikedBtn() {
    const btn = document.getElementById("like-btn") as HTMLButtonElement | null;
    if (!btn) return;
    btn.classList.add("border-rose-500/50","text-rose-500","dark:text-rose-400");
    const svg = btn.querySelector("svg");
    svg?.classList.remove("fill-none");
    svg?.classList.add("fill-current");
    btn.disabled = true;
  }

  // ── Auth chooser flow ────────────────────────────────────────────────────────
  function hideForms() { hideEl("bsky-login-form"); hideEl("masto-login-form"); }

  function openLoginForm(proto: "atproto" | "activitypub") {
    hideForms();
    if (proto === "atproto") {
      showEl("bsky-login-form");
      (document.getElementById("bsky-handle-input") as HTMLInputElement | null)?.focus();
    } else {
      showEl("masto-login-form");
      (document.getElementById("masto-instance-input") as HTMLInputElement | null)?.focus();
    }
  }

  // Ask the user how they want to authenticate, then resume pendingAction.
  function promptAuth() {
    const promptEl = document.getElementById("fedi-chooser-prompt");
    if (promptEl) {
      promptEl.textContent = pendingAction === "like"
        ? "Sign in to like this post"
        : "Sign in to post your reply";
    }
    showEl("fedi-chooser");
    if (availableProtos.length === 1) {
      openLoginForm(availableProtos[0]);
    } else {
      hideForms();
    }
    document.getElementById("fedi-chooser")?.scrollIntoView({ behavior: "smooth", block: "center" });
  }

  // ── Auth: Bluesky ────────────────────────────────────────────────────────────
  async function getBskyClient(): Promise<BrowserOAuthClient> {
    if (!bskyClient) {
      const isLoopback = location.hostname === "localhost" || location.hostname === "127.0.0.1";
      if (isLoopback) {
        // Local dev: hosted client metadata can't be used. AT Protocol requires a
        // loopback client whose redirect uses 127.0.0.1 (not "localhost", per RFC 8252).
        const redirectUri = `http://127.0.0.1:${location.port}/oauth/callback`;
        const scope = "atproto transition:generic";
        const clientId = `http://localhost?redirect_uri=${encodeURIComponent(redirectUri)}&scope=${encodeURIComponent(scope)}`;
        bskyClient = await BrowserOAuthClient.load({ clientId, handleResolver: "https://bsky.social" });
      } else {
        bskyClient = await BrowserOAuthClient.load({ clientId: `${location.origin}/client-metadata.json`, handleResolver: "https://bsky.social" });
      }
    }
    return bskyClient;
  }

  async function tryRestoreBluesky() {
    if (!bskyRawUri) return;
    try {
      const client = await getBskyClient();
      const result = await client.initRestore();
      if (result?.session) {
        bskySession = result.session;
        const profileRes = await fetch(`https://public.api.bsky.app/xrpc/app.bsky.actor.getProfile?actor=${encodeURIComponent(bskySession.did)}`);
        const profile = await profileRes.json();
        onLoggedIn("bluesky", { handle: profile.handle, avatar: profile.avatar ?? "", displayName: profile.displayName ?? "" });
      }
    } catch { /* no stored session */ }
  }

  async function loginBluesky() {
    const input = document.getElementById("bsky-handle-input") as HTMLInputElement;
    const errEl = document.getElementById("bsky-login-error")!;
    const handle = input?.value.trim();
    if (!handle) return;

    const btn = document.getElementById("btn-bsky-signin") as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Opening…";
    errEl.classList.add("hidden");

    try {
      const client = await getBskyClient();
      const session = await client.signInPopup(handle);
      bskySession = session;
      const profileRes = await fetch(`https://public.api.bsky.app/xrpc/app.bsky.actor.getProfile?actor=${encodeURIComponent(session.did)}`);
      const profile = await profileRes.json();
      onLoggedIn("bluesky", { handle: profile.handle, avatar: profile.avatar ?? "", displayName: profile.displayName ?? "" });
    } catch (e: any) {
      errEl.textContent = e?.message?.includes("popup") ? "Popup was blocked — please allow popups for this site." : (e?.message ?? "Sign-in failed.");
      errEl.classList.remove("hidden");
    } finally {
      btn.disabled = false;
      btn.textContent = "Continue →";
    }
  }

  // ── Auth: Mastodon ───────────────────────────────────────────────────────────
  function tryRestoreMastodon() {
    const raw = localStorage.getItem("fedi-masto-session");
    if (!raw) return;
    mastoSession = JSON.parse(raw) as MastoSession;
    if (!activePlatform) {
      onLoggedIn("mastodon", { handle: mastoSession.acct, avatar: mastoSession.avatar, displayName: mastoSession.displayName });
    }
  }

  async function loginMastodon() {
    const input = document.getElementById("masto-instance-input") as HTMLInputElement;
    const errEl = document.getElementById("masto-login-error")!;
    let instance = input?.value.trim().replace(/^https?:\/\//, "").replace(/\/$/, "");
    if (!instance) return;

    const btn = document.getElementById("btn-masto-signin") as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Opening…";
    errEl.classList.add("hidden");

    try {
      const redirectUri = `${location.origin}/oauth/mastodon-callback`;
      const appRes = await fetch(`https://${instance}/api/v1/apps`, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams({
          client_name: "davidebri.github.io",
          redirect_uris: redirectUri,
          scopes: "write:favourites write:statuses read:accounts",
          website: location.origin,
        }).toString(),
      });
      if (!appRes.ok) throw new Error(`Could not register on ${instance} (${appRes.status})`);
      const app = await appRes.json();

      localStorage.setItem("fedi-masto-pending", JSON.stringify({ instance, clientId: app.client_id, clientSecret: app.client_secret, redirectUri }));
      localStorage.setItem("fedi-oauth-return-to", location.href);

      const authUrl = `https://${instance}/oauth/authorize?client_id=${encodeURIComponent(app.client_id)}&redirect_uri=${encodeURIComponent(redirectUri)}&response_type=code&scope=write:favourites+write:statuses+read:accounts`;
      const popup = window.open(authUrl, "mastodon-auth", "width=600,height=700,scrollbars=yes,resizable=yes");

      if (!popup) throw new Error("Popup was blocked — please allow popups for this site.");

      window.addEventListener("message", (e: MessageEvent) => {
        if (e.origin !== location.origin || e.data?.type !== "fedi-masto-auth") return;
        if (e.data.error) {
          errEl.textContent = e.data.error;
          errEl.classList.remove("hidden");
          btn.disabled = false;
          btn.textContent = "Continue →";
          return;
        }
        mastoSession = e.data.session as MastoSession;
        onLoggedIn("mastodon", { handle: mastoSession!.acct, avatar: mastoSession!.avatar, displayName: mastoSession!.displayName });
        btn.disabled = false;
        btn.textContent = "Continue →";
      }, { once: true });
    } catch (e: any) {
      errEl.textContent = e?.message ?? "Sign-in failed.";
      errEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Continue →";
    }
  }

  // ── Signed-in state ──────────────────────────────────────────────────────────
  function onLoggedIn(platform: "bluesky" | "mastodon", { handle, avatar, displayName }: { handle: string; avatar: string; displayName: string }) {
    activePlatform = platform;

    hideEl("fedi-chooser");
    hideForms();
    showEl("fedi-user-bar");

    const handleEl = document.getElementById("fedi-user-handle");
    const avatarEl = document.getElementById("fedi-user-avatar") as HTMLImageElement | null;
    const badgeEl = document.getElementById("fedi-platform-badge");

    if (handleEl) handleEl.textContent = handle;
    if (badgeEl) badgeEl.textContent = `on ${PLATFORM_LABEL[platform]}`;
    if (avatarEl) {
      avatarEl.src = avatar;
      avatarEl.alt = `${displayName || handle} avatar`;
      avatarEl.onerror = () => { avatarEl.style.display = "none"; };
    }
    updateCharCount();

    // Resume whatever the user was trying to do before we asked them to sign in.
    const resume = pendingAction;
    pendingAction = null;
    if (resume === "like") handleLike();
    else if (resume === "comment") handleSubmitComment();
  }

  function updateCharCount() {
    const textarea = document.getElementById("fedi-comment-input") as HTMLTextAreaElement | null;
    const charEl = document.getElementById("fedi-char-count");
    if (!textarea || !charEl) return;
    const len = textarea.value.length;
    const limit = activePlatform === "bluesky" ? 300 : activePlatform === "mastodon" ? 500 : null;
    charEl.textContent = limit ? `${len} / ${limit}` : (len ? `${len}` : "");
  }

  // ── Logout ───────────────────────────────────────────────────────────────────
  async function logout() {
    if (bskySession) {
      try { const c = await getBskyClient(); await c.revoke(bskySession.did); } catch {}
      bskySession = null;
    }
    if (mastoSession) {
      localStorage.removeItem("fedi-masto-session");
      mastoSession = null;
    }
    activePlatform = null;
    hideEl("fedi-user-bar");
    updateCharCount();
  }

  // ── Like (unified) ───────────────────────────────────────────────────────────
  function handleLike() {
    if (!activePlatform) {
      pendingAction = "like";
      promptAuth();
      return;
    }
    if (activePlatform === "bluesky") likeBsky();
    else likeMasto();
  }

  async function likeBsky() {
    if (!bskySession || !bskyCid) return;
    const btn = document.getElementById("like-btn") as HTMLButtonElement;
    btn.disabled = true;
    try {
      await bskySession.fetchHandler("/xrpc/com.atproto.repo.createRecord", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          repo: bskySession.did,
          collection: "app.bsky.feed.like",
          record: { $type: "app.bsky.feed.like", subject: { uri: bskyAtUri, cid: bskyCid }, createdAt: new Date().toISOString() }
        }),
      });
      totalLikes += 1;
      updateTotals();
      localStorage.setItem(`fedi-liked-bsky-${bskyAtUri}`, "1");
      markLikedBtn();
    } catch {
      btn.disabled = false;
    }
  }

  // Resolve the article's Mastodon post to an id that is valid on the *user's* instance.
  // Same instance → the id from the URL works directly; otherwise resolve it via search.
  async function resolveMastoLocalId(session: MastoSession): Promise<string> {
    const { instance, access_token } = session;
    const { hostname: originInstance, pathname } = new URL(mastoRawUrl);
    const originStatusId = pathname.split("/").pop();
    if (originStatusId && instance === originInstance) return originStatusId;

    const search = await fetch(`https://${instance}/api/v2/search?q=${encodeURIComponent(mastoRawUrl)}&resolve=true&type=statuses`, {
      headers: { Authorization: `Bearer ${access_token}` },
    }).then(r => r.json());
    const localId: string | undefined = search.statuses?.[0]?.id;
    if (!localId) throw new Error("Couldn't find this post on your instance.");
    return localId;
  }

  async function likeMasto() {
    if (!mastoSession) return;
    const btn = document.getElementById("like-btn") as HTMLButtonElement;
    btn.disabled = true;
    try {
      const { instance, access_token } = mastoSession;
      const localId = await resolveMastoLocalId(mastoSession);

      await fetch(`https://${instance}/api/v1/statuses/${localId}/favourite`, {
        method: "POST", headers: { Authorization: `Bearer ${access_token}` },
      });
      totalLikes += 1;
      updateTotals();
      const statusId = new URL(mastoRawUrl).pathname.split("/").pop()!;
      localStorage.setItem(`fedi-liked-masto-${statusId}`, "1");
      markLikedBtn();
    } catch {
      btn.disabled = false;
    }
  }

  // ── Comment submission (unified) ─────────────────────────────────────────────
  async function handleSubmitComment() {
    const textarea = document.getElementById("fedi-comment-input") as HTMLTextAreaElement | null;
    const statusEl = document.getElementById("fedi-submit-status");
    const submitBtn = document.getElementById("btn-submit-comment") as HTMLButtonElement | null;
    const text = textarea?.value.trim();
    if (!text || !submitBtn) return;

    // Not signed in yet — ask how, then come back here.
    if (!activePlatform) {
      pendingAction = "comment";
      promptAuth();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Posting…";
    if (statusEl) statusEl.classList.add("hidden");

    try {
      if (activePlatform === "bluesky" && bskySession && bskyRawUri) {
        await bskySession.fetchHandler("/xrpc/com.atproto.repo.createRecord", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            repo: bskySession.did,
            collection: "app.bsky.feed.post",
            record: {
              $type: "app.bsky.feed.post",
              text,
              reply: { root: { uri: bskyAtUri, cid: bskyCid }, parent: { uri: bskyAtUri, cid: bskyCid } },
              createdAt: new Date().toISOString(),
            },
          }),
        });
      } else if (activePlatform === "mastodon" && mastoSession && mastoRawUrl) {
        const { instance, access_token } = mastoSession;
        // Must resolve the post on the user's instance first — otherwise the reply
        // would be posted as a standalone status and never appear in the thread.
        const localId = await resolveMastoLocalId(mastoSession);
        const form = new FormData();
        form.append("status", text);
        form.append("in_reply_to_id", localId);
        await fetch(`https://${instance}/api/v1/statuses`, {
          method: "POST", headers: { Authorization: `Bearer ${access_token}` }, body: form,
        });
      }

      // Optimistically show the new reply in the unified stream.
      addOwnComment(text);

      if (textarea) { textarea.value = ""; updateCharCount(); }
      if (statusEl) { statusEl.textContent = "Reply posted!"; statusEl.classList.remove("hidden"); setTimeout(() => statusEl.classList.add("hidden"), 4000); }
    } catch (e: any) {
      if (statusEl) { statusEl.textContent = e?.message ?? "Failed to post reply."; statusEl.classList.remove("hidden"); }
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Post reply";
    }
  }

  function addOwnComment(text: string) {
    if (!activePlatform) return;
    const handleEl = document.getElementById("fedi-user-handle");
    const avatarEl = document.getElementById("fedi-user-avatar") as HTMLImageElement | null;
    const handle = handleEl?.textContent ?? "you";
    comments.push({
      platform: activePlatform,
      name: handle,
      handle,
      avatar: avatarEl?.src ?? "",
      permalink: "#",
      html: `<p>${escapeHtml(text)}</p>`,
      date: new Date().toISOString(),
      likeCount: 0,
    });
    totalReplies += 1;
    updateTotals();
    renderStream();
  }

  // ── Wire up ──────────────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>(".fedi-proto-btn").forEach((b) => {
    b.addEventListener("click", () => openLoginForm(b.dataset.proto as "atproto" | "activitypub"));
  });
  document.getElementById("btn-bsky-signin")?.addEventListener("click", loginBluesky);
  document.getElementById("bsky-handle-input")?.addEventListener("keydown", (e) => { if ((e as KeyboardEvent).key === "Enter") loginBluesky(); });
  document.getElementById("btn-masto-signin")?.addEventListener("click", loginMastodon);
  document.getElementById("masto-instance-input")?.addEventListener("keydown", (e) => { if ((e as KeyboardEvent).key === "Enter") loginMastodon(); });
  document.getElementById("btn-logout")?.addEventListener("click", logout);
  document.getElementById("like-btn")?.addEventListener("click", handleLike);
  document.getElementById("btn-submit-comment")?.addEventListener("click", handleSubmitComment);
  document.getElementById("fedi-comment-input")?.addEventListener("input", updateCharCount);

  // ── Boot ─────────────────────────────────────────────────────────────────────
  const fetches: Promise<void>[] = [];
  if (bskyRawUri) {
    fetches.push(loadBluesky(bskyRawUri).then(() => { loadedCount++; }).catch(() => { erroredCount++; }));
  }
  if (mastoRawUrl) {
    fetches.push(loadMastodon(mastoRawUrl).then(() => { loadedCount++; }).catch(() => { erroredCount++; }));
  }
  Promise.allSettled(fetches).then(finishLoad);
  // Safety net: never let the skeleton spin forever (e.g. a hanging/blocked request)
  setTimeout(finishLoad, 8000);

  // Restore sessions in parallel with the thread fetches
  tryRestoreMastodon();
  if (bskyRawUri) tryRestoreBluesky();
</script>

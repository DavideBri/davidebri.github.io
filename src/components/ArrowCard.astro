---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
  index?: number;
}

const { entry, index } = Astro.props;

const date = entry.data.date
  ? entry.data.date.toLocaleDateString("en-us", { month: "short", year: "numeric" })
  : null;
---

<a href={`/${entry.collection}/${entry.slug}`} class="group relative flex items-baseline gap-4 py-4 pr-10 border-t border-[var(--border)] transition-colors duration-300 ease-in-out">
  {index !== undefined && (
    <span class="index-num w-8 shrink-0" aria-hidden="true">
      {String(index).padStart(2, "0")}
    </span>
  )}
  <div class="flex flex-col flex-1 gap-0.5 min-w-0">
    <div class="flex items-baseline justify-between gap-4">
      <span class="font-display font-medium text-lg leading-snug text-[var(--text-primary)] group-hover:text-[var(--text-accent)] transition-colors duration-300 ease-in-out truncate">
        {entry.data.title}
      </span>
      {date && (
        <span class="index-meta hidden sm:block shrink-0">
          {date}
        </span>
      )}
    </div>
    <div class="text-sm text-[var(--text-secondary)] truncate">
      {entry.data.description}
    </div>
  </div>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class="absolute top-1/2 right-2 -translate-y-1/2 size-5 stroke-2 fill-none stroke-current group-hover:stroke-[var(--accent)]">
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
    <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
  </svg>
</a>

---
import { cn } from "@lib/utils";

type Props = {
  href: string;
  external?: boolean;
  underline?: boolean;
}

const { href, external, underline = true, ...rest } = Astro.props;
---

<a 
  href={href} 
  target={ external ? "_blank" : "_self" } 
  class={cn("inline-block decoration-[var(--border-accent)] decoration-1 hover:decoration-[var(--accent)] text-current hover:text-[var(--text-accent)] transition-colors duration-300 ease-in-out", underline && "underline underline-offset-[3px]")}
  {...rest}>
  <slot/>
</a>
